# .env.example
# DO NOT put real passwords in this file. 
# Copy this to .env and fill in the blanks.

#Just comment out which one you are currently not using.
#This DATABASE_URL will give you remote access to live db container. 
DATABASE_URL="postgresql://pantry_admin:ADD_PASSWORD_HERE@44.218.218.180:5432/smart_pantry?schema=public"

#This DATABASE_URL will give you access to your local db container. 
DATABASE_URL="postgresql://pantry_admin:ADD_PASSWORD_HERE@localhost:5432/smart_pantry?schema=public"

# Spoonacular API
SPOONACULAR_API_KEY=eb7b8f7bc0964161a823405c89cc0f02

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="use-a-long-random-string-here"

# ─── Email (GoDaddy SMTP) ─────────────────────────────────────────────────────
# GoDaddy's outgoing mail server. Use port 465 with SSL (recommended)
# or port 587 with TLS (EMAIL_SECURE=false).
EMAIL_HOST="smtpout.secureserver.net"
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER="your-email@yourdomain.com"
EMAIL_PASS="your-godaddy-email-password"
EMAIL_FROM_NAME="PantryMonium"
